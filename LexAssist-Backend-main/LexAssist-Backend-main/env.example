# Copy this file to .env and fill in your real values.
# Do not commit .env or your service account JSON.

# MongoDB Atlas connection string (include /lawbot_db before the ?)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/lawbot_db?retryWrites=true&w=majority

# Path to your Firebase service account JSON file (same folder as main.py or full path)
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# Optional: for deployment. Get a free key at https://console.groq.com
# If set, the app uses Groq cloud AI instead of local Ollama.
# GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Optional: for deployment. Paste the entire Firebase service account JSON as one line (no newlines).
# Use this when the host has no file upload (e.g. Railway, Render). Leave unset for local.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Optional: add frontend URL for CORS when deployed, e.g. https://lexassist.vercel.app
# CORS_ORIGINS_EXTRA=https://your-app.vercel.app
